{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Write",
      "Edit",
      "WebFetch(*)",

      "Bash(scp *)",
      "Bash(date)",
      "Bash(date *)",
      "Bash(find *)",
      "Bash(lsof *)",
      "Bash(jq *)",
      "Bash(curl *)",

      "Bash(git -C * *)",
      "Bash(git *)",
      "Bash(git * | *)",
      "Bash(git -C * * | *)",
      "Bash(git * | * | *)",

      "Bash(gh pr view *)",
      "Bash(gh pr list)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list)",
      "Bash(gh issue list *)",
      "Bash(gh run view *)",
      "Bash(gh run list)",
      "Bash(gh run list *)",
      "Bash(gh repo view *)",
      "Bash(gh auth status)",
      "Bash(gh api *)",

      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(tree *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(stat *)",
      "Bash(mkdir *)",
      "Bash(rmdir *)",
      "Bash(diff *)",
      "Bash(shasum *)",
      "Bash(md5 *)",
      "Bash(file *)",
      "Bash(awk *)",
      "Bash(cut *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(comm *)",
      "Bash(column *)",
      "Bash(xxd *)",

      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(dbt *)",
      "Bash(oxy *)",
      "Bash(duckdb *)",
      "Bash(yamllint *)",
      "Bash(yq *)",
      "Bash(bash *)",
      "Bash(bash -n *)",
      "Bash(shellcheck *)",

      "Bash(pip list *)",
      "Bash(pip show *)",
      "Bash(pip freeze *)",
      "Bash(pip3 list *)",
      "Bash(pip3 show *)",
      "Bash(pip3 freeze *)",
      "Bash(brew list *)",
      "Bash(brew info *)",
      "Bash(brew --version)",
      "Bash(brew --prefix *)",

      "Bash(chmod *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(test *)",
      "Bash([ * ])",
      "Bash([[ * ]])",
      "Bash(for * in *; do *; done)",
      "Bash(while * do * done)",
      "Bash(if * then * fi)",
      "Bash(less *)",
      "Bash(more *)",
      "Bash(sed *)",
      "Bash(cmp *)",
      "Bash(python3 -m json.tool *)",
      "Bash(pwd)",
      "Bash(uptime)",
      "Bash(whoami)",

      "Bash(./run.sh)",
      "Bash(./run.sh *)",
      "Bash(./scripts/*.sh)",
      "Bash(./scripts/setup/*.sh)",
      "Bash(./scripts/setup/bootstrap.sh *)",

      "Bash(git init *)",
      "Bash(git remote *)",
      "Bash(ssh -T git@github.com)",

      "Bash(tailscale status)",
      "Bash(tailscale status *)",

      "Bash(sudo nginx *)",
      "Bash(sudo systemctl reload nginx)",
      "Bash(sudo systemctl status nginx)",
      "Bash(sudo systemctl restart nginx)",
      "Bash(sudo systemctl daemon-reload)",
      "Bash(sudo tail * /var/log/nginx/*)",
      "Bash(sudo cat /etc/nginx/*)",
      "Bash(sudo grep * /etc/nginx/*)",
      "Bash(sudo sed -n * /etc/nginx/*)",
      "Bash(sudo cp * /etc/nginx/*)",
      "Bash(sudo cp * /etc/systemd/system/*)",
      "Bash(sudo mv * /etc/nginx/*)",
      "Bash(sudo mv * /etc/systemd/system/*)",
      "Bash(sudo ln -s * /etc/nginx/*)",
      "Bash(sudo ln -s * /etc/systemd/system/*)",
      "Bash(sudo ln * /etc/nginx/*)",
      "Bash(sudo ln * /etc/systemd/system/*)",

      "Skill(update-config)",
      "Skill(update-config:*)",

      "Write(.claude/settings.local.json)",
      "Read(.claude/settings.local.json)",
      "Write(.claude/worktrees/*/.claude/settings.local.json)",
      "Read(.claude/worktrees/*/.claude/settings.local.json)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Bash(launchctl *)",
      "Bash(eval *)",
      "Bash(curl * | bash*)",
      "Bash(curl * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(git reset --hard *)",
      "Bash(git reset --hard)",
      "Bash(git -C * reset --hard *)",
      "Bash(git -C * reset --hard)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git -C * push --force *)",
      "Bash(git -C * push -f *)",
      "Bash(git branch -d *)",
      "Bash(git branch -D *)",
      "Bash(git -C * branch -d *)",
      "Bash(git -C * branch -D *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git -C * push --force-with-lease *)",
      "Bash(rm -rf *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rfd *)",
      "Bash(rm -fr *)",
      "Bash(sudo rm *)",
      "Bash(sudo dd *)",
      "Bash(sudo chmod * /etc/*)",
      "Bash(sudo chown * /etc/*)",
      "Bash(sudo cp * /etc/*)",
      "Bash(sudo mv * /etc/*)",
      "Bash(sudo ln * /etc/*)",
      "Bash(sudo ln -s * /etc/*)",
      "Bash(sudo bash *)",
      "Bash(sudo sh *)",
      "Bash(sudo -i)",
      "Bash(sudo -s)",
      "Bash(aws * terminate-*)",
      "Bash(aws ec2 stop-instances *)",
      "Bash(aws ec2 reboot-instances *)",
      "Bash(aws ec2 delete-*)",
      "Bash(aws ec2 modify-*)",
      "Bash(aws ec2 revoke-security-group-*)",
      "Bash(aws ec2 authorize-security-group-*)",
      "Bash(aws ec2 run-instances *)",
      "Bash(aws s3 rb *)",
      "Bash(aws s3 rm * --recursive*)",
      "Bash(aws s3api delete-*)",
      "Bash(aws iam create-*)",
      "Bash(aws iam delete-*)",
      "Bash(aws iam attach-*)",
      "Bash(aws iam detach-*)",
      "Bash(aws iam put-*)",
      "Bash(aws iam update-*)"
    ]
  },
  "autoMode": {
    "environment": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous.sh",
            "statusMessage": "Checking shell shape..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"LOGGING REMINDER: Before ending this session, verify LOG.md and TASKS.md are current. Log format: HH:MM ET timestamp. Check: (1) any completed tasks marked [x] in TASKS.md, (2) decisions/blockers added to LOG.md, (3) Current Status and Last Updated fields updated.\"}'",
            "statusMessage": "Checking log compliance..."
          }
        ]
      }
    ]
  }
}
